# Copy to .env and fill in secrets: cp .env.example .env
# Quick Slack check (no HubSpot): SLACK_BOT_TOKEN=... python -m p2p_digest.main --test-slack

# HubSpot private app token (crm.objects.deals.read, crm.schemas.deals.read)
HUBSPOT_ACCESS_TOKEN=

# Internal name of the P2P Partner property on deals (default: p2p_partner)
HUBSPOT_DEMAND_PARTNER_PROPERTY=p2p_partner
# Optional: exclude deals with blank P2P Partner (HAS_PROPERTY filter)
# HUBSPOT_REQUIRE_P2P_PARTNER=true
# Optional: only these HubSpot enum values (exact strings, comma-separated, e.g. Media.net,Nexxen)
# HUBSPOT_P2P_PARTNER_VALUES=

# Either set pipeline id, or set label to auto-resolve
HUBSPOT_PIPELINE_ID=
# HUBSPOT_PIPELINE_LABEL=P2P

# Stage labels used to resolve stage IDs (case-insensitive contains match)
HUBSPOT_STAGE_FORM_SIGNED_LABEL=Form signed
HUBSPOT_STAGE_INTEGRATION_LABEL=Integration

# Or set explicit HubSpot stage ids if label matching fails
# HUBSPOT_STAGE_FORM_SIGNED_ID=
# HUBSPOT_STAGE_INTEGRATION_ID=

# If hs_date_entered_<stageId> does not populate, paste full internal property names from HubSpot
# HUBSPOT_DATE_ENTERED_FORM_SIGNED_PROP=
# HUBSPOT_DATE_ENTERED_INTEGRATION_PROP=

# Saved CRM board/view id from the HubSpot URL (…/views/58461098/board) — for labels only; the API
# cannot fetch “all deals in this view”. Approximate the board with pipeline + deal stages below.
HUBSPOT_CRM_VIEW_ID=58461098
# Comma-separated internal deal stage ids that match your board COLUMNS (Settings → Deals → Pipelines).
# Leave empty to include every deal in the pipeline.
# HUBSPOT_DEALSTAGE_IDS=1256781119,1273609
# Optional AND filters (JSON array of HubSpot search filter objects), e.g. owner or custom property:
# HUBSPOT_EXTRA_FILTERS_JSON=[{"propertyName":"hubspot_owner_id","operator":"EQ","value":"123"}]

# Start of “time to Integration” for completed deals: form_signed (hs_date_entered) or created (deal create date)
HUBSPOT_FUNNEL_START_DATE=created

# Which deals to pull: form_signed_column (EQ Form signed stage), stages_in_list (HUBSPOT_DEALSTAGE_IDS), entire_pipeline
HUBSPOT_DEAL_SCOPE=form_signed_column

# Est. revenue while a deal sits in Form signed (Slack per-deal lines): dollars per day
# FORM_SIGNED_CARRY_USD_PER_DAY=1000

# Comma-separated deal property internal names; first non-empty wins for “last activity” per deal
# (logged sales activity / emails / last modified — not Conversations inbox). Defaults are sensible if omitted.
# HUBSPOT_LAST_ACTIVITY_PROPERTIES=hs_last_sales_activity_timestamp,hs_last_logged_outgoing_email_date,hs_lastmodifieddate

# --- Slack (pick ONE delivery method) ---

# Option A: Incoming webhook (channel is fixed when you create the webhook)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Option B: Bot token + channel ID (chat.postMessage)
# Create a Slack app, install to workspace, Bot User OAuth Token (xoxb-...), scopes: chat:write
SLACK_BOT_TOKEN=
# #hubspot-signed-integrating-tracker
SLACK_CHANNEL_ID=C0AQUT92ZU7
# Optional: also post a copy to your DM with the bot (e.g. D0AQJHGUJU8)
SLACK_DM_CHANNEL_ID=

# Claude (Anthropic) API key for the written summary (omit if you always use --no-llm)
ANTHROPIC_API_KEY=

# Optional: override model id
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
