# HubSpot private app token (crm.objects.deals.read, crm.schemas.deals.read)
HUBSPOT_ACCESS_TOKEN=

# Deal property internal name for Demand / P2P partner (check HubSpot settings)
HUBSPOT_DEMAND_PARTNER_PROPERTY=demand_partner

# Either set pipeline id, or set label to auto-resolve
HUBSPOT_PIPELINE_ID=
# HUBSPOT_PIPELINE_LABEL=P2P

# Stage labels used to resolve stage IDs (case-insensitive contains match)
HUBSPOT_STAGE_FORM_SIGNED_LABEL=Form signed
HUBSPOT_STAGE_INTEGRATION_LABEL=Integration

# Or set explicit HubSpot stage ids if label matching fails
# HUBSPOT_STAGE_FORM_SIGNED_ID=
# HUBSPOT_STAGE_INTEGRATION_ID=

# If hs_date_entered_<stageId> does not populate, paste full internal property names from HubSpot
# HUBSPOT_DATE_ENTERED_FORM_SIGNED_PROP=
# HUBSPOT_DATE_ENTERED_INTEGRATION_PROP=

# Slack incoming webhook URL for the channel
SLACK_WEBHOOK_URL=

# Claude (Anthropic) API key for the written summary
ANTHROPIC_API_KEY=

# Optional: override model id
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
